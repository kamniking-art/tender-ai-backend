DB_NAME=tender_ai
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=tender_ai_db
DB_PORT=5432

# Legacy aliases (optional). Keep equal to DB_* if used.
POSTGRES_DB=tender_ai
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Optional explicit DSN overrides. When empty, docker-compose builds DSN from DB_*.
DATABASE_URL=
DATABASE_URL_SYNC=

SECRET_KEY=change_me_to_long_random_string
ACCESS_TOKEN_EXPIRE_MINUTES=60
ALGORITHM=HS256
STORAGE_ROOT=/data
DOCUMENTS_SUBDIR=tender_docs
TASK_SLA_CHECK_INTERVAL_MINUTES=5
TELEGRAM_NOTIFY_INTERVAL_MINUTES=5
MONITORING_INTERVAL_MINUTES=360

APP_HOST=0.0.0.0
APP_PORT=8000
PUBLIC_BASE_URL=http://127.0.0.1:8000
# Telegram credentials are per-company in company.profile.telegram
EIS_OPENDATA_BASE_URL=https://zakupki.gov.ru
EIS_OPENDATA_SEARCH_PATH=/epz/opendata/search/results.html
# Optional explicit API endpoints when discovered:
# EIS_OPENDATA_SEARCH_API_URL=
# EIS_OPENDATA_DATASET_API_URL=

APP_VERSION=unknown
APP_BUILT_AT=unknown
APP_VERSION_IMAGE=unknown
APP_BUILT_AT_IMAGE=unknown
WEB_COOKIE_SECURE=false

AI_EXTRACTOR_MODE=mock
AI_EXTRACTOR_BASE_URL=
AI_EXTRACTOR_API_KEY=
AI_EXTRACTOR_TIMEOUT_SEC=60
AI_EXTRACTOR_MAX_CHARS=120000
AUTH_DISABLED=false
AUTH_DISABLED_COMPANY_EMAIL=admin@demo.ru
INGESTION_RUN_ONCE_COOLDOWN_MINUTES=10
ALLOW_KNOWN_DATASETS_FALLBACK=false
# Comma-separated dataset ids or direct file URLs for fallback mode.
EIS_OPENDATA_KNOWN_DATASETS=
EIS_SITE_DEFAULT_QUERIES=гранит,керамогранит,плита гранитная,памятник,благоустройство,бордюр гранитный,щебень гранитный,мемориал,стела,облицовочная плитка
EIS_SOURCE_BLOCKED_COOLDOWN_MINUTES=30
EIS_SOURCE_REQUEST_DELAY_SEC=2.0
EIS_SOURCE_REQUEST_JITTER_SEC=1.5
EIS_SOURCE_PAGE_DELAY_MIN_SEC=1.8
EIS_SOURCE_PAGE_DELAY_MAX_SEC=4.2
EIS_SOURCE_LONG_PAUSE_MIN_SEC=8.0
EIS_SOURCE_LONG_PAUSE_MAX_SEC=15.0
EIS_SOURCE_LONG_PAUSE_EVERY_MIN_PAGES=10
EIS_SOURCE_LONG_PAUSE_EVERY_MAX_PAGES=15
EIS_SITE_MAX_AGE_DAYS=60
EIS_BROWSER_STATE_DIR=/opt/tender_ai_backend/runtime/eis_browser_state
